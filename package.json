{
  "name": "fast-agent-marketplace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck:workspace": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "typecheck": "npm run typecheck:workspace && npm run typecheck:web",
    "build:runtime": "tsup --config tsup.config.ts",
    "build:web": "npm run build --workspace @marketplace/web",
    "build": "npm run typecheck && npm run build:runtime && npm run build:web",
    "test": "vitest run",
    "test:mcp:ci-smoke": "node --import tsx scripts/verify-fast-pay-mcp-ci.ts",
    "test:web:smoke": "npm run build:web && playwright test --config apps/web/playwright.config.ts",
    "dev:api": "tsx apps/api/src/index.ts",
    "dev:apify-service": "tsx apps/apify-service/src/index.ts",
    "dev:facilitator": "tsx apps/facilitator/src/index.ts",
    "dev:tavily-service": "tsx apps/tavily-service/src/index.ts",
    "dev:valyu-service": "tsx apps/valyu-service/src/index.ts",
    "dev:worker": "tsx apps/worker/src/index.ts",
    "dev:web": "npm run dev --workspace @marketplace/web",
    "cli": "tsx packages/cli/src/index.ts",
    "start:api": "node dist/apps/api/index.js",
    "start:apify-service": "node dist/apps/apify-service/index.js",
    "start:facilitator": "node dist/apps/facilitator/index.js",
    "start:tavily-service": "node dist/apps/tavily-service/index.js",
    "start:valyu-service": "node dist/apps/valyu-service/index.js",
    "start:worker": "node dist/apps/worker/index.js",
    "start:web": "npm run start --workspace @marketplace/web",
    "start:cli": "node dist/packages/cli/index.js"
  },
  "dependencies": {
    "@fastxyz/fast-connector": "^0.1.1",
    "@fastxyz/sdk": "^0.2.5",
    "@fastxyz/x402-client": "^0.1.3",
    "@fastxyz/x402-facilitator": "^1.0.1",
    "@fastxyz/x402-server": "^1.0.1",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "ajv": "^8.18.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.24.6"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.27.4",
    "@next/swc-linux-x64-gnu": "^16.1.7",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "lightningcss-linux-x64-gnu": "1.31.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "jsdom": "^29.0.1",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
