{
  "name": "fast-agent-marketplace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:runtime": "tsup --config tsup.config.ts",
    "build": "npm run typecheck && npm run build:runtime",
    "test": "vitest run",
    "dev:api": "tsx apps/api/src/index.ts",
    "dev:facilitator": "tsx apps/facilitator/src/index.ts",
    "dev:worker": "tsx apps/worker/src/index.ts",
    "cli": "tsx packages/cli/src/index.ts",
    "start:api": "node dist/apps/api/index.js",
    "start:facilitator": "node dist/apps/facilitator/index.js",
    "start:worker": "node dist/apps/worker/index.js",
    "start:cli": "node dist/packages/cli/index.js"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@fastxyz/x402-facilitator": "^0.1.0",
    "@fastxyz/sdk": "^0.1.8",
    "@fastxyz/x402-client": "^0.1.0",
    "@fastxyz/x402-server": "^0.1.0",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
