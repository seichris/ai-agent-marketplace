  "endpoints": [
    {
      "endpointType": "marketplace_proxy",
      "operation": "scrape-products",
      "title": "Scrape Products",
      "description": "Extract Amazon product, pricing, and review data from one or more product or category URLs.",
      "billingType": "fixed_x402",
      "price": "$0.60",
      "method": "POST",
      "mode": "async",
      "asyncStrategy": "poll",
      "asyncTimeoutMs": 1800000,
      "pollPath": "/runs/poll",
      "requestSchemaJson": {
        "type": "object",
        "required": [
          "startUrls"
        ],
        "properties": {
          "startUrls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "url"
              ],
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "additionalProperties": false
            }
          },
          "maxItems": {
            "type": "integer",
            "minimum": 1
          },
          "country": {
            "type": "string",
            "minLength": 2
          }
        },
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "startUrls": [
          {
            "url": "https://www.amazon.com/dp/B09X7MPX8L"
          }
        ],
        "maxItems": 10,
        "country": "US"
      },
      "responseExample": {
        "runId": "apify_run_123",
        "status": "SUCCEEDED",
        "items": [
          {
            "asin": "B09X7MPX8L",
            "title": "Example Product",
            "price": {
              "value": 145.5,
              "currency": "$"
            }
          }
        ]
      },
      "usageNotes": "Use this for Amazon-specific product and category scraping when you need ASIN-aware output and Amazon pricing data.",
      "upstreamBaseUrl": "https://fastmainnetapifyamazon.8o.vc",
      "upstreamPath": "/scrape-products",
      "upstreamAuthMode": "none"
    }
  ]
