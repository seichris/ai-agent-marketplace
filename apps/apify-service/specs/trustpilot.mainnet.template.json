          },
          "maxReviewsPerCompany": {
            "type": "integer",
            "minimum": 1
          },
          "sort": {
            "type": "string",
            "enum": ["recency", "relevance"]
          },
          "includeCompanyInfo": {
            "type": "boolean"
          },
          "stars": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          },
          "language": {
            "type": "string"
          },
          "verifiedOnly": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "companyUrls": ["pipedrive.com"],
        "maxReviewsPerCompany": 25,
        "sort": "recency",
        "includeCompanyInfo": true,
        "stars": [4, 5]
      },
