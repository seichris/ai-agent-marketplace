              "minLength": 1
            }
          },
          "contact_location": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "contact_city": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "company_industry": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "seniority_level": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "fetch_count": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "contact_job_title": [
          "Marketing Manager"
        ],
        "contact_location": [
          "United States"
        ],
        "company_industry": [
          "SaaS"
        ],
        "seniority_level": [
          "Manager"
        ],
        "fetch_count": 250
