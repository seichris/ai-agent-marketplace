        "items": [
          {
            "full_name": "Jane Example",
            "job_title": "Marketing Manager",
            "email": "jane@example.com",
            "company_name": "Example SaaS"
          }
        ]
      },
      "usageNotes": "Good for prospecting when you need broad filtered lead generation rather than enrichment of a known list.",
