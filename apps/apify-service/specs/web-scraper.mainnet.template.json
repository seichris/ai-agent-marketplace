              ],
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "additionalProperties": false
            }
          },
          "pageFunction": {
            "type": "string",
            "minLength": 1
          },
          "linkSelector": {
            "type": "string"
          },
          "globs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "pseudoUrls": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "maxCrawlPages": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "startUrls": [
          {
            "url": "https://example.com/products"
          }
        ],
        "pageFunction": "async function pageFunction(context) { const { request, page } = context; return { url: request.url, title: await page.title() }; }",
        "linkSelector": "a.product-link",
        "maxCrawlPages": 25
      },
      "responseExample": {
        "runId": "apify_run_123",
        "status": "SUCCEEDED",
        "items": [
          {
            "url": "https://example.com/products/widget",
            "title": "Widget"
          }
        ]
