          }
        ]
      },
      "usageNotes": "Use this when you know the creator handle and want the latest or most popular profile videos.",
      "upstreamBaseUrl": "https://fastmainnetapifytiktok.8o.vc",
      "upstreamPath": "/profile-posts",
      "upstreamAuthMode": "none"
