    "slug": "apify-contact-info-scraper",
    "apiNamespace": "apify-contact-info",
    "name": "Contact Info Scraper",
    "tagline": "Extract emails, phone numbers, and social profile links from websites through a Fast-native async proxy.",
    "about": "Contact Info Scraper exposes an Apify-backed website contact extraction workflow through the marketplace for lead enrichment, prospecting, and site-level contact discovery.",
    "categories": [
      "Lead Generation",
      "Sales",
      "Research"
    ],
    "promptIntro": "I want to use the Contact Info Scraper service on Fast Marketplace.",
    "setupInstructions": [
      "Fund a Fast wallet on mainnet.",
