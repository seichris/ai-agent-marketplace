    "websiteUrl": "https://fastmainnetapifycontactinfo.8o.vc",
    "payoutWallet": "fast1rv8wsdd5pnkwt4u637g2yj4tpuyq26rzw8380rfhpnsnljz7v3tqv4njuq"
  },
  "endpoints": [
    {
      "endpointType": "marketplace_proxy",
      "operation": "extract-contact-details",
      "title": "Extract Contact Details",
      "description": "Crawl one or more websites and extract emails, phone numbers, and social profile links.",
      "billingType": "fixed_x402",
      "price": "$0.35",
      "method": "POST",
      "mode": "async",
      "asyncStrategy": "poll",
      "asyncTimeoutMs": 1800000,
      "pollPath": "/runs/poll",
      "requestSchemaJson": {
        "type": "object",
        "required": [
          "startUrls"
        ],
        "properties": {
          "startUrls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "url"
              ],
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "additionalProperties": false
            }
          },
          "maxPages": {
            "type": "integer",
            "minimum": 1
          },
          "mergeContacts": {
            "type": "boolean"
          },
          "enrichSocialProfiles": {
            "type": "boolean"
          },
          "enableLeadEnrichment": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "startUrls": [
          {
            "url": "https://example.com"
          }
        ],
        "maxPages": 25,
        "mergeContacts": true,
        "enrichSocialProfiles": false,
        "enableLeadEnrichment": false
      },
      "responseExample": {
        "runId": "apify_run_123",
        "status": "SUCCEEDED",
        "items": [
          {
            "url": "https://example.com/contact",
            "emails": [
              "hello@example.com"
            ],
            "phones": [
              "+1 555-0100"
            ]
          }
        ]
      },
      "usageNotes": "Use this when the source of truth is a company website rather than a people database or social network profile.",
      "upstreamBaseUrl": "https://fastmainnetapifycontactinfo.8o.vc",
      "upstreamPath": "/extract-contact-details",
      "upstreamAuthMode": "none"
    }
  ]
}
