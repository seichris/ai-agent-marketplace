    {
      "endpointType": "marketplace_proxy",
      "operation": "search-places",
      "title": "Search Places",
      "description": "Search Google Maps by term and location and return matching places.",
      "billingType": "fixed_x402",
      "price": "$0.25",
      "method": "POST",
      "mode": "async",
      "asyncStrategy": "poll",
      "asyncTimeoutMs": 1800000,
      "pollPath": "/runs/poll",
      "requestSchemaJson": {
        "type": "object",
        "required": [
          "searchStringsArray"
        ],
        "properties": {
          "searchStringsArray": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "locationQuery": {
            "type": "string"
          },
          "maxCrawledPlacesPerSearch": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": true
      },
      "responseSchemaJson": {
        "type": "object",
        "additionalProperties": true
      },
      "requestExample": {
        "searchStringsArray": [
          "coffee shops"
        ],
        "locationQuery": "San Francisco, California, United States",
        "maxCrawledPlacesPerSearch": 20
      },
      "responseExample": {
        "runId": "apify_run_123",
        "status": "SUCCEEDED",
        "items": [
          {
            "title": "Example Cafe",
            "address": "San Francisco, CA",
            "website": "https://example-cafe.com"
          }
        ]
      },
      "usageNotes": "Use this as the default entry point for map search and local business discovery.",
      "upstreamBaseUrl": "https://fastmainnetapifygoogleplaces.8o.vc",
      "upstreamPath": "/search-places",
      "upstreamAuthMode": "none"
    },
    {
      "endpointType": "marketplace_proxy",
      "operation": "place-details",
      "title": "Place Details",
      "description": "Fetch detailed Google Maps fields for known place IDs or direct place URLs.",
      "billingType": "fixed_x402",
      "price": "$0.30",
      "method": "POST",
      "mode": "async",
      "asyncStrategy": "poll",
      "asyncTimeoutMs": 1800000,
      "pollPath": "/runs/poll",
      "requestSchemaJson": {
        "type": "object",
        "properties": {
          "placeIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "startUrls": {
            "type": "array",
